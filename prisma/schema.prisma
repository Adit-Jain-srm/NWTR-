generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum Role {
  TENANT
  OWNER
  RM
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DEACTIVATED
}

enum PropertyStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  LISTED
  OCCUPIED
  DELISTED
}

enum DepositStatus {
  INITIATED
  PENDING_PAYMENT
  CONFIRMED
  ACTIVE
  MATURED
  RETURNED
  CANCELLED
}

enum PayoutStatus {
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum KYCTier {
  TIER_0
  TIER_1
  TIER_2
  TIER_3
}

enum KYCStatus {
  PENDING
  UNDER_REVIEW
  VERIFIED
  REJECTED
}

enum AgreementStatus {
  DRAFT
  PENDING_SIGNATURES
  SIGNED
  ACTIVE
  TERMINATED
  EXPIRED
}

enum InstrumentType {
  FIXED_DEPOSIT
  GOVERNMENT_BOND
  TREASURY_BILL
  LIQUID_FUND
  CORPORATE_BOND
}

// ─── Models ───

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  phone     String?    @unique
  password  String
  firstName String
  lastName  String
  role      Role       @default(TENANT)
  status    UserStatus @default(ACTIVE)
  kycTier   Int        @default(0)
  avatar    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  properties       Property[]
  deposits         Deposit[]       @relation("TenantDeposits")
  ownerDeposits    Deposit[]       @relation("OwnerDeposits")
  kycRecords       KYCRecord[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  rmAssignmentsAsRM    RMAssignment[] @relation("RMUser")
  rmAssignmentsAsClient RMAssignment[] @relation("ClientUser")
  agreementsAsTenant   Agreement[] @relation("TenantAgreements")
  agreementsAsOwner    Agreement[] @relation("OwnerAgreements")
  payoutsAsOwner       Payout[]

  @@map("users")
}

model Property {
  id            String         @id @default(uuid())
  ownerId       String
  title         String
  description   String?
  bhk           Int
  area          Int
  address       Json
  city          String
  locality      String
  marketValue   Decimal        @db.Decimal(15, 2)
  minDeposit    Decimal?       @db.Decimal(15, 2)
  maxDeposit    Decimal?       @db.Decimal(15, 2)
  amenities     String[]
  images        String[]
  status        PropertyStatus @default(DRAFT)
  verifiedAt    DateTime?
  verifiedBy    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  owner    User      @relation(fields: [ownerId], references: [id])
  deposits Deposit[]

  @@index([city, locality])
  @@index([status])
  @@index([marketValue])
  @@map("properties")
}

model Deposit {
  id              String        @id @default(uuid())
  tenantId        String
  ownerId         String
  propertyId      String
  amount          Decimal       @db.Decimal(15, 2)
  percentage      Decimal       @db.Decimal(5, 2)
  status          DepositStatus @default(INITIATED)
  tenure          Int           @default(12)
  monthlyPayout   Decimal?      @db.Decimal(12, 2)
  nachMandateId   String?
  initiatedAt     DateTime      @default(now())
  confirmedAt     DateTime?
  maturesAt       DateTime?
  returnedAt      DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant      User         @relation("TenantDeposits", fields: [tenantId], references: [id])
  owner       User         @relation("OwnerDeposits", fields: [ownerId], references: [id])
  property    Property     @relation(fields: [propertyId], references: [id])
  investments Investment[]
  payouts     Payout[]
  agreement   Agreement?

  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@map("deposits")
}

model Investment {
  id             String         @id @default(uuid())
  depositId      String
  instrumentType InstrumentType
  instrumentRef  String?
  principal      Decimal        @db.Decimal(15, 2)
  interestRate   Decimal        @db.Decimal(5, 3)
  maturityDate   DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  deposit Deposit @relation(fields: [depositId], references: [id])

  @@map("investments")
}

model Payout {
  id            String       @id @default(uuid())
  depositId     String
  ownerId       String
  amount        Decimal      @db.Decimal(12, 2)
  status        PayoutStatus @default(SCHEDULED)
  scheduledDate DateTime
  executedAt    DateTime?
  failureReason String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  deposit Deposit @relation(fields: [depositId], references: [id])
  owner   User    @relation(fields: [ownerId], references: [id])

  @@index([ownerId])
  @@index([status])
  @@index([scheduledDate])
  @@map("payouts")
}

model Agreement {
  id          String          @id @default(uuid())
  depositId   String          @unique
  tenantId    String
  ownerId     String
  documentUrl String?
  status      AgreementStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  signedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  deposit Deposit @relation(fields: [depositId], references: [id])
  tenant  User    @relation("TenantAgreements", fields: [tenantId], references: [id])
  owner   User    @relation("OwnerAgreements", fields: [ownerId], references: [id])

  @@map("agreements")
}

model KYCRecord {
  id         String    @id @default(uuid())
  userId     String
  tier       KYCTier
  status     KYCStatus @default(PENDING)
  documents  Json?
  notes      String?
  verifiedBy String?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("kyc_records")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([resource, action])
  @@index([createdAt])
  @@map("audit_logs")
}

model RMAssignment {
  id        String   @id @default(uuid())
  rmId      String
  clientId  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rm     User @relation("RMUser", fields: [rmId], references: [id])
  client User @relation("ClientUser", fields: [clientId], references: [id])

  @@unique([rmId, clientId])
  @@map("rm_assignments")
}
